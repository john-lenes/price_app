# ─────────────────────────────────────────────────────────────────────────────
# Price Monitor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=price_monitor
POSTGRES_USER=price_user
POSTGRES_PASSWORD=price_pass

DATABASE_URL=postgresql+asyncpg://price_user:price_pass@db:5432/price_monitor
DATABASE_URL_SYNC=postgresql://price_user:price_pass@db:5432/price_monitor

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Scraping Behaviour ────────────────────────────────────────────────────────
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0
REQUEST_TIMEOUT=15
MAX_RETRIES=3
DEFAULT_CHECK_INTERVAL_MINUTES=30

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_NAME=Price Monitor
EMAILS_FROM_EMAIL=your_email@gmail.com

# ── SendGrid (alternative to SMTP — set USE_SENDGRID=true to enable) ──────────
USE_SENDGRID=false
SENDGRID_API_KEY=

# ── WhatsApp via Twilio ──────────────────────────────────────────────────────
# Sign up at https://www.twilio.com/try-twilio
# Enable WhatsApp sandbox or go live with a WhatsApp Business Account
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── WhatsApp via Z-API (alternative — set USE_ZAPI=true to enable) ───────────
USE_ZAPI=false
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3010","http://localhost:80","http://localhost"]
